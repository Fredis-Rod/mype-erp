# Copia este archivo a ".env.local" y completa con los valores de tu proyecto Supabase.
# (Settings -> API en el panel de Supabase). El anon key es público (seguro en el frontend);
# la seguridad real la dan las políticas RLS, no el ocultamiento de esta clave.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY
